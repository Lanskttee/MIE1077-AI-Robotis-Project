# Copy this file to .env and fill in your key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model selection. Sonnet is recommended for tool-calling quality.
# Options: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
HOMEMATE_MODEL=claude-sonnet-4-6

# If 1, skip real Claude calls and use the deterministic MockLLM. Useful for
# offline development.
HOMEMATE_USE_MOCK_LLM=0

# If 1, skip webcam + DeepFace and use the keyboard-driven mock emotion.
HOMEMATE_USE_MOCK_EMOTION=0
