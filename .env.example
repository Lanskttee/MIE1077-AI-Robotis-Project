# Copy this file to .env and fill in your key(s).
# Never commit .env — it is gitignored.

# Anthropic Claude (optional if you use OpenAI instead)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT-4o-mini + Whisper STT + TTS (preferred teammate path)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model selection.
# Claude: claude-sonnet-4-6, claude-opus-4-6, ...
# OpenAI: set HOMEMATE_OPENAI_MODEL (default gpt-4o-mini) when using OPENAI_API_KEY
HOMEMATE_MODEL=claude-sonnet-4-6
HOMEMATE_OPENAI_MODEL=gpt-4o-mini
HOMEMATE_TTS_VOICE=nova

# If 1, skip real LLM calls and use the deterministic MockLLM. Useful for
# offline development.
HOMEMATE_USE_MOCK_LLM=0

# If 1, skip webcam + DeepFace and use the keyboard-driven mock emotion.
HOMEMATE_USE_MOCK_EMOTION=0
